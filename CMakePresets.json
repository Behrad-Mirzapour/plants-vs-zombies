{
    "version": 8,
    "configurePresets": [
        {
            "name": "mingw-debug",
            "displayName": "MinGW Debug",
            "description": "Build with MinGW using MinGW Makefiles",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "environment": {
                "PATH": "$penv{PATH};C:/MinGW/bin"
            }
        },
        {
            "name": "mingw-release",
            "displayName": "MinGW Release",
            "description": "Build with MinGW using MinGW Makefiles",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            },
            "environment": {
                "PATH": "$penv{PATH};C:/MinGW/bin"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "build-debug",
            "configurePreset": "mingw-debug"
        },
        {
            "name": "build-release",
            "configurePreset": "mingw-release"
        }
    ]
}